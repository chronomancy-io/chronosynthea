root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{rs,go,py,swift,c,h,asm,forth}]
indent_style = space
indent_size = 4

[*.{js,ts,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
indent_style = space
indent_size = 2
max_line_length = 100
trim_trailing_whitespace = false

[Makefile]
indent_style = tab

[*.{asm,s,a65,inc}]
indent_style = space
indent_size = 8
